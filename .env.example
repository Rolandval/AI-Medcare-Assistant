# ============================================
# AI-Medcare-Assistant — Environment Variables
# ============================================
# Скопіюй цей файл в .env і заповни значення

# ---- Database ----
POSTGRES_USER=medcare
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=medcare
DATABASE_URL=postgresql+asyncpg://medcare:your_strong_password_here@localhost:5433/medcare

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Claude API (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=medcare-files
R2_PUBLIC_URL=https://pub-xxx.r2.dev
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# ---- JWT ----
JWT_SECRET_KEY=your_very_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
# Для production: HTTPS URL твого сервера
TELEGRAM_WEBHOOK_URL=https://api.yourdomain.com/webhook/telegram

# ---- App Settings ----
APP_NAME=AI-Medcare-Assistant
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
# Розділені комою
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# ---- Survey Schedule (UTC) ----
MORNING_SURVEY_HOUR=5
MORNING_SURVEY_MINUTE=30
EVENING_SURVEY_HOUR=17
EVENING_SURVEY_MINUTE=0

# ---- AI Settings ----
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
AI_ANALYSIS_TIMEOUT=60

# ---- File Upload Limits ----
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic
ALLOWED_DOC_TYPES=application/pdf,image/jpeg,image/png
ALLOWED_AUDIO_TYPES=audio/ogg,audio/mpeg,audio/wav,audio/mp4
